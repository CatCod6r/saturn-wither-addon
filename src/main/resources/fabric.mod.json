{
  "schemaVersion": 1,
  "id": "saturn-wither-addon",
  "version": "${version}",
  "name": "Saturn Wither Addon",
  "description": "A custom Meteor Client addon.",
  "authors": [
    "seasnail"
  ],
  "contact": {
    "repo": "https://github.com/MeteorDevelopment/meteor-addon-template"
  },
  "icon": "assets/saturnwither/icon.png",
  "environment": "client",
  "entrypoints": {
    "meteor": [
      "com.example.saturnwither.SaturnWitherAddon"
    ]
  },
  "mixins": [
    "saturn-wither-addon.mixins.json"
  ],
  "custom": {
    "meteor-client:color": "225,25,25"
  },
  "depends": {
    "java": ">=21",
    "minecraft": ["${mc_version}"],
    "meteor-client": "*"
  }
}
